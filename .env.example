# Town Warden environment example
ENVIRONMENT=local
TOWN_CONFIG=config/towns/blackpool.json
DATABASE_URL=
ADMIN_TOKEN=change-me
SOURCE_REFRESH_SECONDS=60
ALLOW_SIMULATION=false
POLICE_CANDIDATE_LIMIT=80
MAX_NEW_EVENTS_PER_FETCH=8
EVENT_RETENTION_DAYS=90
ALERT_RETENTION_DAYS=90
RISK_SNAPSHOT_RETENTION_DAYS=30

# Legacy geographic overrides are optional. Prefer editing TOWN_CONFIG.
TOWN_WARDEN_AREA_NAME=Blackpool
TOWN_WARDEN_MIN_LAT=53.73
TOWN_WARDEN_MAX_LAT=53.90
TOWN_WARDEN_MIN_LNG=-3.10
TOWN_WARDEN_MAX_LNG=-2.95

STREET_MANAGER_ENABLED=false
STREET_MANAGER_API_KEY=
