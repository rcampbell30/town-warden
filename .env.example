# Town Warden environment example
# Current demo uses backend/config.py defaults.
# Future production version should read these through environment variables.

ALLOW_SIMULATION=false
ENVIRONMENT=local
ADMIN_TOKEN=change-me-for-admin-actions
SOURCE_REFRESH_SECONDS=60
POLICE_CANDIDATE_LIMIT=80
MAX_NEW_EVENTS_PER_FETCH=8
STREET_MANAGER_ENABLED=false
STREET_MANAGER_API_KEY=
